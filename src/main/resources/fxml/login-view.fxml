<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.s4m.poo.controller.LoginController"
            stylesheets="@/css/login-style.css">

    <children>

        <VBox alignment="CENTER" spacing="5"
              AnchorPane.topAnchor="100"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">
            <Label fx:id="mainTitleLabel" text="QUIZ MASTER" styleClass="main-title"/>
            <Label fx:id="subtitleLabel" text="Login to your account" styleClass="subtitle"/>
        </VBox>

        <VBox alignment="CENTER"
              AnchorPane.leftAnchor="200"
              AnchorPane.rightAnchor="200"
              AnchorPane.topAnchor="280"
              maxWidth="400">

            <VBox fx:id="loginBox"
                  spacing="20" maxWidth="400" styleClass="auth-box">

                <VBox spacing="15" prefWidth="300">
                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="usernameField" promptText="Enter email"/>

                    <Label text="Password" styleClass="input-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter password"/>

                    <Label fx:id="loginErrorLabel" text=""
                           style="-fx-text-fill: #ff6347; -fx-font-weight: bold; -fx-alignment: center;"/>

                    <HBox spacing="20" alignment="CENTER">
                        <Button fx:id="loginButton" text="Login" onAction="#handleLoginButton"/>
                        <Button fx:id="signUpButton" text="Sign Up" onAction="#showSignUpView" styleClass="signup-button"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="signUpBox"
                  spacing="20" maxWidth="400" styleClass="auth-box" visible="false" managed="false">

                <VBox spacing="15" prefWidth="300">
                    <Label text="New Username" styleClass="input-label"/>
                    <TextField fx:id="newUsernameField" promptText="Choose a username"/>

                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="Enter your email"/>

                    <Label text="New Password" styleClass="input-label"/>
                    <PasswordField fx:id="newPasswordField" promptText="Choose a password"/>

                    <Label text="Confirm Password" styleClass="input-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"/>

                    <Label fx:id="registerErrorLabel" text=""
                           style="-fx-text-fill: #ff6347; -fx-font-weight: bold; -fx-alignment: center;"/>

                    <HBox spacing="20" alignment="CENTER">
                        <Button fx:id="registerButton" text="Register" onAction="#handleRegisterButton" styleClass="register-button"/>
                        <Button fx:id="backToLoginButton" text="Back to Login" onAction="#showLoginView" styleClass="back-button"/>
                    </HBox>
                </VBox>
            </VBox>

        </VBox>

    </children>

</AnchorPane>